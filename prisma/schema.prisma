generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exercise {
  id           String            @id
  name         String            @unique
  category     String?
  unit         String?
  direction    ExerciseDirection
  bestValue    Float
  worstValue   Float
  roundingStep Float             @default(0.5)
  isActive     Boolean           @default(true)
  isCore       Boolean           @default(false)
  Measurement  Measurement[]

  @@index([isActive])
  @@index([isCore])
}

model Measurement {
  id         String   @id
  playerId   String
  exerciseId String
  date       DateTime @db.Date
  value      Float
  source     String?
  createdBy  String?
  createdAt  DateTime @default(now())
  Exercise   Exercise @relation(fields: [exerciseId], references: [id])
  Player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, exerciseId, date])
  @@index([exerciseId, date])
  @@index([playerId, date])
}

model Player {
  id              String        @id
  teamId          String
  name            String
  birthYear       Int?
  primaryPosition String?
  isActive        Boolean       @default(true)
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  Measurement     Measurement[]
  Team            Team          @relation(fields: [teamId], references: [id])

  @@unique([teamId, name])
  @@index([teamId, isActive])
}

model Team {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  Player    Player[]
}

enum ExerciseDirection {
  HIGHER_BETTER
  LOWER_BETTER
}
